(* Generated by esgg output from highlight_optional_parent/query.json based on highlight_optional_parent/mapping.json *)
type 'key doc_count = { key: 'key; doc_count: int }
type 'a buckets = { buckets: 'a list }
type int_as_float =
  float wrap <ocaml t="int" wrap="int_of_float" unwrap="float_of_int">
type 'a value_agg' = { value: 'a }
type 'a value_agg =
  'a value_agg' wrap
    <ocaml
       t="'a" wrap="fun { value; } -> value" unwrap="fun value -> { value; }">
type basic_json <ocaml module="Json" t="t"> = abstract
type text = {
  ?en: string wrap <ocaml module="Content.Text.En"> nullable;
  ?fr: string wrap <ocaml module="Content.Text.Fr"> nullable
}
type content = { text: text }
type text1 = {
  en: string wrap <ocaml module="Summary.Text.En">;
  fr: string wrap <ocaml module="Summary.Text.Fr">
}
type summary = { ?text: text1 nullable }
type _source = {
  ?content: content nullable;
  summary: summary;
  title: string wrap <ocaml module="Title">
}
type highlight = {
  ~content: content list;
  ~summary_text <json name="summary.text">: text1 list;
  ~title: string wrap <ocaml module="Title"> list
}
type hit = { _id: string; _source: _source; ?highlight: highlight nullable }
type hits = { total: int; ~hits: hit list }
type reason = { type_ <json name="type">: string; ?reason: string nullable }
type failure = {
  reason: reason;
  ?index: string nullable;
  ?node: string nullable;
  ?shard: int nullable;
  ?status: string nullable
}
type _shards = {
  total: int;
  successful: int;
  skipped: int;
  failed: int;
  ?failures: failure list nullable
}
type result = { hits: hits; ?_shards: _shards nullable }
